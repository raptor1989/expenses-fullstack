{
  "name": "@expenses/web",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "description": "React frontend for the household expenses management app",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc && vite build",
    "format": "prettier --config ./.prettierrc --write \"**/*.{ts,tsx}\"",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@expenses/shared": "*",
    "@mui/icons-material": "6.4.12",
    "@mui/material": "6.4.12",
    "@mui/x-date-pickers": "7.29.4",
    "@nivo/bar": "^0.99.0",
    "@nivo/core": "0.99.0",
    "@nivo/line": "0.99.0",
    "@nivo/pie": "0.99.0",
    "axios": "1.18.0",
    "dayjs": "1.11.21",
    "formik": "2.4.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "7.18.0",
    "yup": "1.7.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.2",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.5",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "@vitejs/plugin-react": "4.5.1",
    "eslint": "10.5.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "17.6.0",
    "prettier": "^3.5.3",
    "rimraf": "6.0.1",
    "typescript": "6.0.3",
    "vite": "6.3.5",
    "vitest": "^3.0.0"
  }
}
