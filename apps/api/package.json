{
  "name": "@expenses/api",
  "version": "1.0.0",
  "description": "Express.js backend API for the Expenses Management app",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --config ./.prettierrc --write \"**/*.{ts,tsx}\"",
    "test": "jest --config jest.config.js --runInBand --forceExit",
    "db:migrate": "ts-node src/db/migrate.ts"
  },
  "keywords": [
    "expenses",
    "api",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@expenses/shared": "*",
    "bcryptjs": "3.0.3",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "express-validator": "7.3.2",
    "jsonwebtoken": "9.0.3",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bcryptjs": "3.0.0",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/ms": "2.1.0",
    "@types/node": "24.13.2",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "eslint": "10.5.0",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "rimraf": "6.0.1",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  }
}
